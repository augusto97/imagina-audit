# Modo
APP_ENV=production
APP_DEBUG=false

# API Keys (opcionales — mejoran cuotas de PageSpeed)
GOOGLE_PAGESPEED_API_KEY=

# Admin
ADMIN_PASSWORD_HASH=

# Rate Limiting
RATE_LIMIT_MAX_PER_HOUR=10

# Cache
CACHE_TTL_SECONDS=86400

# CORS — Cambiar a tu dominio real
ALLOWED_ORIGIN=*

# Branding
COMPANY_NAME=Imagina WP
COMPANY_WHATSAPP=+573001234567
