# Dependencies
frontend/node_modules/
# frontend/dist/ NO se ignora — viaja con el repo para que el deploy sea un
# simple `git pull` sin Node.js en el hosting. Se regenera tras cada cambio
# de frontend antes del commit.

# Environment
backend/.env
backend/.env.*
!backend/.env.example
deploy/output/.env
deploy/output/.env.*
*.db

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
backend/logs/*.log
backend/cache/*.json

# Build
*.tsbuildinfo

# Test dependencies (dev only, never deployed)
backend/vendor/
backend/.phpunit.cache/
backend/composer.lock
frontend/coverage/
